# Kalshi credentials (fill in after account setup)
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=/home/milwrite/kalshi/kalshi-key.key

# Demo mode (set to false for live trading)
KALSHI_USE_DEMO=true

# Strategy config
WEATHER_EDGE_THRESHOLD=0.06    # 6% minimum edge to place order
CPI_EDGE_THRESHOLD=0.07        # 7% minimum edge
ORDER_CONTRACTS=1              # contracts per order (start small)
SCAN_INTERVAL_SEC=60           # seconds between full market scans

# Risk controls
MAX_DAILY_TRADES=200           # hard cap across all strategies per day
MAX_OPEN_POSITIONS=50          # max total open contracts at once
MAX_DAILY_LOSS_CENTS=5000      # halt if down $50 on the day

# Position manager
TARGET_PROFIT_PCT=0.60         # close when up 60% of max gain
STOP_LOSS_PCT=0.40             # close when down 40% of entry cost
CLOSE_BEFORE_EXPIRY_MIN=15     # close positions 15 min before market expiry

# BLS CPI release date (format: YYYY-MM-DD) — set on release days
# BLS_RELEASE_DATE=2026-04-10

# Optional: BLS API key (doubles rate limit, free to register)
# BLS_API_KEY=your-bls-key

# Set to 1 to bypass CPI timing gate (useful for testing)
# FORCE_CPI_RUN=1
