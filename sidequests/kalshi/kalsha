#!/usr/bin/env bash
# kalsha — Kalshi toolset CLI wrapper
# Connected to the same account as the main runner (same .env / API key).
#
# Usage:
#   kalsha scan [--dry-run] [--strategy NAME]   run one scan pass
#   kalsha run [--dry-run]                       continuous loop
#   kalsha status                                today's P&L + positions
#   kalsha signals [N]                           tail last N signal log entries
#   kalsha trades  [N]                           tail last N trade log entries
#   kalsha markets [PREFIX]                      list open Kalshi markets (optional prefix filter)
#   kalsha balance                               print account balance
#   kalsha test STRATEGY                         dry-run a single strategy now
#   kalsha strategies                            list all available strategies

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Activate venv if present
if [[ -f venv/bin/activate ]]; then
    source venv/bin/activate
fi

# ~/kalshi/.env is the canonical credentials file
if [[ -f "$HOME/kalshi/.env" ]]; then
    set -a; source "$HOME/kalshi/.env"; set +a
fi
# Local .env can override individual vars
if [[ -f .env ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

CMD="${1:-help}"
shift || true

case "$CMD" in
    scan)
        echo "[kalsha] Running single scan pass..."
        python runner.py --now "$@"
        ;;

    run)
        echo "[kalsha] Starting continuous scan loop..."
        python runner.py "$@"
        ;;

    status)
        python runner.py --status
        ;;

    signals)
        N="${1:-20}"
        LOGFILE="logs/signals.jsonl"
        if [[ ! -f "$LOGFILE" ]]; then
            echo "No signals log yet."
        else
            echo "=== Last $N signals ==="
            tail -n "$N" "$LOGFILE" | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        r = json.loads(line)
        print(f\"  {r.get('ts','?')[:19]}  {r.get('strategy','?'):10s}  {r.get('ticker','?'):30s}  side={r.get('side','?'):4s}  edge={r.get('edge',0)*100:+.1f}%\")
    except:
        print(line.rstrip())
"
        fi
        ;;

    trades)
        N="${1:-20}"
        LOGFILE="logs/trades.jsonl"
        if [[ ! -f "$LOGFILE" ]]; then
            echo "No trades log yet."
        else
            echo "=== Last $N trades ==="
            tail -n "$N" "$LOGFILE" | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        r = json.loads(line)
        print(f\"  {r.get('ts','?')[:19]}  {r.get('strategy','?'):10s}  {r.get('ticker','?'):30s}  {r.get('side','?'):3s}  @{r.get('price','?'):3}c  status={r.get('status','?')}\")
    except:
        print(line.rstrip())
"
        fi
        ;;

    markets)
        PREFIX="${1:-}"
        python3 - "$PREFIX" <<'PYEOF'
import sys, os
sys.path.insert(0, '.')
from dotenv import load_dotenv
load_dotenv()
from core.client import KalshiClient

prefix = sys.argv[1] if len(sys.argv) > 1 else ""
client = KalshiClient()
try:
    markets = client.get_markets(limit=200)
    filtered = [m for m in markets if prefix.upper() in m.get("ticker","").upper()] if prefix else markets
    print(f"{'Ticker':<40} {'Title':<50} Status")
    print("-" * 100)
    for m in filtered[:50]:
        print(f"  {m.get('ticker',''):<38} {(m.get('title') or m.get('subtitle') or '')[:48]:<50} {m.get('status','')}")
    if len(filtered) > 50:
        print(f"  ... and {len(filtered)-50} more")
except Exception as e:
    print(f"Error: {e}")
    print("(Ensure credentials are set in .env)")
PYEOF
        ;;

    balance)
        python3 - <<'PYEOF'
import sys, os
sys.path.insert(0, '.')
from dotenv import load_dotenv
load_dotenv()
from core.client import KalshiClient

client = KalshiClient()
try:
    bal = client.get_balance()
    print("Balance:", bal)
except Exception as e:
    print(f"Error: {e}")
    print("(Ensure credentials are set in .env)")
PYEOF
        ;;

    test)
        STRAT="${1:-weather}"
        echo "[kalsha] Dry-run test: strategy=$STRAT"
        python runner.py --dry-run --now --strategy "$STRAT" \
            ${2:+--force-cpi} 2>&1 | tail -40
        ;;

    strategies)
        echo "Available strategies:"
        echo "  weather    HRRR forecast + NWS live obs vs Kalshi temperature markets"
        echo "  cpi        Cleveland Fed nowcast vs Kalshi CPI contracts"
        echo "  nfp        ADP + BLS data vs Kalshi NFP (jobs) contracts"
        echo "  crypto     Kraken spot price + log-normal model vs Kalshi BTC/ETH/SOL markets"
        echo "  polls      538 + Polymarket cross-calibration vs Kalshi political markets"
        echo "  oil        EIA weekly inventory + WTI spot vs Kalshi energy contracts"
        echo "  hurricane  NHC forecast probabilities vs Kalshi storm/landfall markets"
        echo "  earnings   Historical beat rates + analyst revisions vs Kalshi earnings markets"
        echo "  nba        ESPN live win probability vs Kalshi NBA game markets"
        echo "  fed        Monotonicity arb across Kalshi Fed rate ladder contracts"
        ;;

    help|--help|-h)
        cat <<'HELP'
kalsha — Kalshi information-edge trading toolset

Usage:
  kalsha scan [--dry-run] [--strategy NAME]   run one scan pass (all or single strategy)
  kalsha run  [--dry-run]                     start continuous scan loop
  kalsha status                               today's P&L + open positions
  kalsha signals [N]                          tail last N signal log entries (default: 20)
  kalsha trades  [N]                          tail last N trade log entries  (default: 20)
  kalsha markets [PREFIX]                     list open Kalshi markets
  kalsha balance                              print account balance
  kalsha test STRATEGY                        dry-run a single strategy now
  kalsha strategies                           list all available strategies

Setup:
  cp .env.example .env
  # fill in KALSHI_API_KEY_ID + KALSHI_PRIVATE_KEY_PATH
  pip install -r requirements.txt

Force release-window gates:
  FORCE_CPI_RUN=1 kalsha test cpi
  FORCE_NFP_RUN=1 kalsha test nfp
  FORCE_OIL_RUN=1 kalsha test oil
HELP
        ;;

    *)
        echo "Unknown command: $CMD"
        echo "Run 'kalsha help' for usage."
        exit 1
        ;;
esac
